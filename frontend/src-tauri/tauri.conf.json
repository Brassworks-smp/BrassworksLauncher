{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brassworks Launcher",
  "version": "0.5.3",
  "identifier": "com.brassworks.launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Brassworks Launcher",
        "width": 1200,
        "height": 780,
        "minWidth": 1000,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0d0d0d",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DATA/BrassworksLauncher/instances/**",
          "$DATA/BrassworksLauncher/shared/skins/**",
          "$DATA/BrassworksLauncher/thumbnails/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Launcher for the Brassworks SMP",
    "longDescription": "The Brassworks Launcher installs and launches the Brassworks SMP modpack (NeoForge 1.21.1) and keeps you up to date.",
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwRDcyMjlBREZEQUYyRkEKUldUNjh0cmZtaUxYY0F6VENuWW5ibEZ2S24vTktHWmJJWmlUS0N6b21SN3lDT3pRK0dPSFVwMUYK",
      "endpoints": [
        "https://github.com/Brassworks-smp/BrassworksLauncher/releases/latest/download/latest.json"
      ]
    }
  }
}
